<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Request a Loan — Demo Bank</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="banner">Demo project — no real loan is issued, this only logs a request for the admin</div>
  <%- include('partials/navbar', { active: 'loan' }) %>

  <div class="page-wrap">
    <div class="card">
      <h1 class="page-title">Request a Loan</h1>
      <p>Fill in the details below. This submits a request the admin can see — it does not disburse any funds automatically.</p>

      <% if (typeof sent !== 'undefined' && sent) { %>
        <div class="msg-flash">Your loan request was submitted. The admin will review it.</div>
      <% } %>

      <form method="POST" action="/request-loan">
        <input type="number" step="0.01" name="amount" placeholder="Loan amount (€)" required>
        <select name="term" required>
          <option value="">Repayment term</option>
          <option value="6 months">6 months</option>
          <option value="12 months">12 months</option>
          <option value="24 months">24 months</option>
          <option value="36 months">36 months</option>
        </select>
        <textarea name="purpose" rows="4" placeholder="Purpose of the loan" required></textarea>
        <button type="submit" class="btn-primary" style="width:auto; padding:11px 22px;">Submit request</button>
      </form>
    </div>

    <div class="card">
      <h2 class="section-title" style="margin-top:0;">Your loan requests</h2>
      <% if (loans.length === 0) { %>
        <p style="color:#8a97a0;">No loan requests yet.</p>
      <% } else { %>
        <table>
          <thead><tr><th>Amount</th><th>Term</th><th>Purpose</th><th>Date</th></tr></thead>
          <tbody>
            <% loans.forEach(l => { %>
              <tr>
                <td><%= fmtMoney(l.amount) %></td>
                <td><%= l.term %></td>
                <td><%= l.purpose %></td>
                <td><%= new Date(l.created_at).toLocaleDateString() %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>
</body>
</html>