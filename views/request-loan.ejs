<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Request a Loan — Velnora Finance</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="banner">Demo project — no real loan is issued, this only logs a request for the admin</div>
  <%- include('partials/navbar', { active: 'loan' }) %>

  <div class="loan-page-wrap">
    <div class="loan-page-header">
      <h1>Request a Loan</h1>
      <p>Fill in the details below. This submits a request the admin can review — it does not disburse any real funds.</p>
    </div>

    <% if (typeof sent !== 'undefined' && sent) { %>
      <div class="msg-flash">Your loan request was submitted successfully. The admin will review it shortly.</div>
    <% } %>

    <form method="POST" action="/request-loan" id="loanForm">

      <!-- ============ PERSONAL INFORMATION ============ -->
      <div class="loan-section-card">
        <h2 class="loan-section-title">Personal Information</h2>

        <div class="loan-grid">
          <div class="form-field">
            <label>Full Name</label>
            <input type="text" name="full_name" required value="<%= user.full_name || '' %>">
          </div>

          <div class="form-field">
            <label>Date of Birth</label>
            <input type="date" name="date_of_birth" required>
          </div>

          <div class="form-field">
            <label>Account Number (last 4 digits)</label>
            <input type="text" name="account_last4" maxlength="4" pattern="\d{4}" inputmode="numeric"
                   value="<%= user.account_number ? user.account_number.replace(/\D/g,'') : '' %>" required>
          </div>

          <div class="form-field">
            <label>Employment Status</label>
            <select name="employment_status" required>
              <option value="">Select...</option>
              <option>Full-Time</option>
              <option>Part-Time</option>
              <option>Self-employed</option>
              <option>Retired</option>
              <option>Student</option>
              <option>Unemployed</option>
            </select>
          </div>

          <div class="form-field">
            <label>Annual Income</label>
            <select name="income_range" required>
              <option value="">Select...</option>
              <option>$10,000 - $25,000</option>
              <option>$25,001 - $50,000</option>
              <option>$50,001 - $75,000</option>
              <option>$75,001 - $100,000</option>
              <option>$100,001 - $150,000</option>
              <option>$150,001 - $200,000</option>
              <option>$200,000+</option>
            </select>
          </div>

          <div class="form-field">
            <label>Phone Number</label>
            <input type="tel" name="phone_number" required>
          </div>

          <div class="form-field">
            <label>Country</label>
            <input type="text" name="country" required>
          </div>

          <div class="form-field">
            <label>State</label>
            <input type="text" name="state" required>
          </div>

          <div class="form-field">
            <label>City</label>
            <input type="text" name="city" required>
          </div>
        </div>

        <div class="signature-field">
          <label>Digital Signature</label>
          <p class="signature-hint">Sign using your mouse or finger below.</p>
          <canvas id="signaturePad" class="signature-pad" width="700" height="200"></canvas>
          <div class="signature-actions">
            <button type="button" id="clearSignature" class="btn-clear-sig">Clear Signature</button>
          </div>
          <input type="hidden" name="signature" id="signatureInput">
        </div>
      </div>

      <!-- ============ LOAN DETAILS ============ -->
      <div class="loan-section-card">
        <h2 class="loan-section-title">Loan Details</h2>

        <div class="loan-grid">
          <div class="form-field">
            <label>Loan Amount (€)</label>
            <input type="number" name="amount" step="0.01" min="1" required>
          </div>

          <div class="form-field">
            <label>Loan Type</label>
            <select name="loan_type" required>
              <option value="">Select...</option>
              <option>Personal Loan</option>
              <option>Mortgage</option>
              <option>Home Equity Loan</option>
              <option>Student Loan</option>
              <option>Small Business Loan</option>
            </select>
          </div>

          <div class="form-field">
            <label>Loan Term</label>
            <select name="term" required>
              <option value="">Select...</option>
              <option>3 months</option>
              <option>6 months</option>
              <option>12 months</option>
              <option>36 months</option>
            </select>
          </div>
        </div>

        <div class="form-field form-field-full">
          <label>Reason for Loan</label>
          <textarea name="purpose" rows="4" required placeholder="Briefly describe what this loan is for..."></textarea>
        </div>
      </div>

      <button type="submit" class="btn-hero-primary loan-submit-btn">Submit Loan Request</button>
    </form>

    <div class="loan-section-card loan-history-card">
      <h2 class="loan-section-title">Your Loan Requests</h2>
      <% if (loans.length === 0) { %>
        <p class="loan-history-empty">No loan requests yet.</p>
      <% } else { %>
        <div class="loan-history-scroll">
          <table>
            <thead>
              <tr>
                <th>Amount</th>
                <th>Type</th>
                <th>Term</th>
                <th>Purpose</th>
                <th>Date</th>
              </tr>
            </thead>
            <tbody>
              <% loans.forEach(l => { %>
                <tr>
                  <td><%= fmtMoney(l.amount) %></td>
                  <td><%= l.loan_type || '—' %></td>
                  <td><%= l.term %></td>
                  <td><%= l.purpose %></td>
                  <td><%= new Date(l.created_at).toLocaleDateString() %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>

  <script>
    (function () {
      var canvas = document.getElementById('signaturePad');
      var ctx = canvas.getContext('2d');
      ctx.strokeStyle = '#0b4a5c';
      ctx.lineWidth = 2.2;
      ctx.lineCap = 'round';

      var drawing = false;
      var hasDrawn = false;

      function getPos(e) {
        var rect = canvas.getBoundingClientRect();
        var clientX = e.touches ? e.touches[0].clientX : e.clientX;
        var clientY = e.touches ? e.touches[0].clientY : e.clientY;
        return {
          x: (clientX - rect.left) * (canvas.width / rect.width),
          y: (clientY - rect.top) * (canvas.height / rect.height)
        };
      }

      function start(e) {
        drawing = true;
        hasDrawn = true;
        var pos = getPos(e);
        ctx.beginPath();
        ctx.moveTo(pos.x, pos.y);
        e.preventDefault();
      }
      function move(e) {
        if (!drawing) return;
        var pos = getPos(e);
        ctx.lineTo(pos.x, pos.y);
        ctx.stroke();
        e.preventDefault();
      }
      function end() { drawing = false; }

      canvas.addEventListener('mousedown', start);
      canvas.addEventListener('mousemove', move);
      window.addEventListener('mouseup', end);
      canvas.addEventListener('touchstart', start, { passive: false });
      canvas.addEventListener('touchmove', move, { passive: false });
      canvas.addEventListener('touchend', end);

      document.getElementById('clearSignature').addEventListener('click', function () {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        hasDrawn = false;
      });

      document.getElementById('loanForm').addEventListener('submit', function (e) {
        if (!hasDrawn) {
          e.preventDefault();
          alert('Please sign in the signature box before submitting your loan request.');
          return;
        }
        document.getElementById('signatureInput').value = canvas.toDataURL('image/png');
      });
    })();
  </script>
</body>
</html>