<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Velnora Finance — Banking that works for you</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="banner">Demo project — fictional bank built for coursework, no real money or accounts</div>
  <%- include('partials/public-nav') %>

  <!-- HERO -->
  <section class="hero-split">
    <div class="hero-left">
      <div class="hero-tag">Personal Banking</div>
      <h1>Banking made simple, for every stage of life.</h1>
      <p>Open an account in minutes. Manage checking, savings, loans and cards — all from one clean dashboard.</p>
      <a href="/create-account" class="hero-cta-pill">New user? Create Account</a>
      <p class="hero-alt-link"><a href="/login">Existing user? Log in</a></p>
    </div>
    <div class="hero-right">
      <img src="/images/hero-photo.png" alt="Happy family managing their finances together" class="hero-photo">
    </div>
  </section>

    </section>
<!-- PROMO BANNER -->
  <section class="promo-banner">
    <div class="promo-inner">
      <div class="promo-text">
        <h2>Help Give Every Child Hope for a Better Tomorrow</h2>
        <p>Your donation provides nutritious meals and hope to children facing hunger. Every gift helps change a life.</p>
      </div>
      <a href="/create-account" class="promo-pill">Donate Now</a>
    </div>
  </section>

  <!-- FEATURE CARDS -->
  <section class="feature-section">
    <h2 class="section-heading">Explore what Velnora Finance offers</h2>
    <div class="feature-grid">
      <div class="feature-card" id="checking">
        <div class="feature-icon">🏦</div>
        <h3>Checking Account</h3>
        <p>Everyday spending made easy, with instant transfers and a real-time balance you can always see.</p>
        <a href="/create-account" class="feature-link">Open an account →</a>
      </div>
      <div class="feature-card" id="savings">
        <div class="feature-icon">💰</div>
        <h3>Savings Account</h3>
        <p>Set money aside and watch it grow, with a dedicated savings balance separate from everyday spending.</p>
        <a href="/create-account" class="feature-link">Start saving →</a>
      </div>
      <div class="feature-card" id="loans">
        <div class="feature-icon">📄</div>
        <h3>Loans</h3>
        <p>Request a loan for what matters to you, with flexible terms and a simple request process.</p>
        <a href="/create-account" class="feature-link">Learn more →</a>
      </div>
      <div class="feature-card" id="cards">
        <div class="feature-icon">💳</div>
        <h3>Cards</h3>
        <p>A card that fits in your dashboard, ready whenever you need to spend, freeze, or manage it.</p>
        <a href="/create-account" class="feature-link">Get a card →</a>
      </div>
    </div>
  </section>

  </section>

  <!-- KIDS SAVINGS SPOTLIGHT -->
  <section class="kids-savings-section">
    <div class="kids-savings-inner">
      <div class="kids-savings-header">
        <h2>Start saving for their future today</h2>
        <p>Give your child a head start in life with a dedicated savings account built for growing families. <a href="/create-account">Open a savings account →</a></p>
      </div>
      <div class="kids-savings-content">
        <div class="kids-savings-image">
          <img src="/images/kids-savings.png" alt="Parent and child saving together">
        </div>
        <div class="kids-savings-columns">
          <div class="kids-savings-col">
            <div class="col-tag">Start Early</div>
            <h3>Give your child a head start with their own savings account</h3>
          </div>
          <div class="kids-savings-col">
            <div class="col-tag">Automatic Saving</div>
            <h3>Set up automatic transfers and watch their savings grow</h3>
          </div>
          <div class="kids-savings-col">
            <div class="col-tag">Teach Responsibility</div>
            <h3>Help kids build healthy money habits that last a lifetime</h3>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ENQUIRY BANNER -->
  <section class="enquiry-banner">
    <div class="enquiry-inner">
      <div class="enquiry-text">
        <h2>Have a question? We're ready to help</h2>
        <p>Whether it's about opening an account, a loan request, or anything else — our support team is just a message away.</p>
      </div>
      <a href="/contact" class="enquiry-pill">Speak to an agent</a>
    </div>
  </section>

  </section>

  <!-- FEATURES SPOTLIGHT -->
  <section class="features-spotlight-section">
    <div class="features-spotlight-inner">
      <div class="features-spotlight-text">
        <h2>Powerful features, right at your fingertips</h2>
        <p>From real-time balance tracking to instant transfer and loan requests, Velnora Finance keeps you in control of your money — wherever you are.</p>
        <a href="/create-account" class="btn-outline-pill">Create Account</a>
      </div>
      <div class="features-spotlight-image">
        <img src="/images/features-spotlight.png" alt="Velnora Finance dashboard on mobile">
      </div>
    </div>
  </section>

  <!-- REPORT FRAUD OR SCAMS -->
  <section class="fraud-section">
    <div class="fraud-inner">
      <div class="fraud-text">
        <h2>Report Fraud or Scams</h2>
        <p>If you notice unauthorized transactions, receive suspicious messages, or believe you've been targeted by fraudsters, report it to Velnora Finance immediately. Our dedicated fraud team works around the clock to investigate reports, secure your account, and help protect your funds.</p>
        <div class="fraud-actions">
          <a href="/contact" class="btn-blueprint-solid">Report Fraud</a>
          <a href="/contact" class="btn-blueprint-outline">Security Center</a>
        </div>
      </div>
      
      <div class="fraud-visual">
        <img src="/images/fraud-security.png" alt="Fraud protection and security">
      </div>

    </div>
  </section>

  <!-- MORE INSIGHTS -->
  <section class="insights-section" id="insights">
    <div class="insights-inner">
         <div class="insights-header">
        <h2>More Insights</h2>
      </div>
      <div class="insights-grid">
        <% posts.forEach(post => { %>
          <a href="/blog/<%= post.slug %>" class="insight-card">
            <div class="insight-card-image">
              <img src="/images/blog/<%= post.image %>" alt="<%= post.title %>">
            </div>
            <div class="insight-card-body">
              <div class="insight-card-category"><%= post.category %></div>
              <h3><%= post.title %></h3>
            </div>
          </a>
        <% }) %>
      </div>
    </div>
  </section>


  <!-- CTA BANNER -->
  <section class="cta-banner">
    <h2>Ready to get started?</h2>
    <p>Create your free account and see your dashboard in under a minute.</p>
    <a href="/create-account" class="btn-hero-primary">Create Account</a>
  </section>

  
  </section>

  <!-- FOOTER -->
  <footer class="site-footer">

  <!-- FOOTER -->
  <footer class="site-footer">

    <div class="footer-inner">
      <div class="footer-brand">VELNORA FINANCE</div>
      <div class="footer-links">
        <a href="/about">About Us</a>
        <a href="/contact">Contact Us</a>
        <a href="/contact">Help and Support</a>
        <a href="/login">Log In</a>
        <a href="/create-account">Create Account</a>
      </div>
      <p class="footer-note">Velnora Finance is a fictional bank created for a school project. No real accounts, deposits, or financial services are provided.</p>
    </div>
  </footer>
</body>
</html>