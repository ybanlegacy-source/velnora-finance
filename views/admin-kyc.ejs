<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Review Verification — <%= user.full_name %></title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="admin-wrap">
    <div class="admin-header">
      <h1>Verification Review — <%= user.full_name %> (@<%= user.username %>)</h1>
      <a class="link-quiet" href="/admin">&larr; Back to admin</a>
    </div>

    <% if (!submission) { %>
      <div class="card">
        <p>No submission found for this user.</p>
      </div>
    <% } else { %>

      <div class="card">
        <h3 style="margin-top:0; color:#0b4a5c;">Status</h3>
        <p>
          Current status:
          <% if (submission.status === 'approved') { %>
            <span class="pill-badge pill-approved">Approved</span>
          <% } else if (submission.status === 'rejected') { %>
            <span class="pill-badge pill-rejected">Rejected</span>
          <% } else { %>
            <span class="pill-badge pill-pending">Pending</span>
          <% } %>
        </p>
        <p style="color:#8a97a0; font-size:0.85rem;">
          Submitted: <%= new Date(submission.submitted_at).toLocaleString() %><br>
          ID type: <strong><%= submission.id_type %></strong>
          <% if (submission.reviewed_at) { %>
            <br>Reviewed: <%= new Date(submission.reviewed_at).toLocaleString() %> by <%= submission.reviewed_by %>
            <% if (submission.admin_note) { %><br>Note: <%= submission.admin_note %><% } %>
          <% } %>
        </p>
      </div>

      <div class="card">
        <h3 style="margin-top:0; color:#0b4a5c;">Submitted Documents</h3>
        <div class="kyc-review-grid">
          <div>
            <p class="kyc-review-label">ID Front</p>
            <img src="<%= submission.id_front %>" class="kyc-review-image">
          </div>
          <% if (submission.id_back) { %>
            <div>
              <p class="kyc-review-label">ID Back</p>
              <img src="<%= submission.id_back %>" class="kyc-review-image">
            </div>
          <% } %>
          <div>
            <p class="kyc-review-label">Selfie</p>
            <img src="<%= submission.selfie %>" class="kyc-review-image">
          </div>
        </div>
      </div>

      <% if (submission.status === 'pending') { %>
        <div class="card">
          <h3 style="margin-top:0; color:#0b4a5c;">Decision</h3>
          <div class="kyc-decision-forms">
            <form method="POST" action="/admin/kyc/<%= user.id %>/approve" class="kyc-decision-form">
              <input type="text" name="note" placeholder="Optional note">
              <button type="submit" class="btn-primary" style="width:100%;">Approve</button>
            </form>
            <form method="POST" action="/admin/kyc/<%= user.id %>/reject" class="kyc-decision-form">
              <input type="text" name="note" placeholder="Reason for rejection">
              <button type="submit" class="btn-cancel" style="width:100%; background:#fdecea; color:#c0392b;">Reject</button>
            </form>
          </div>
        </div>
      <% } %>

    <% } %>
  </div>
</body>
</html>