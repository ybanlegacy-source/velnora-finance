<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= post.title %> — Velnora Finance</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="banner">Demo project — articles are for illustrative purposes only</div>
  <% if (loggedIn) { %>
    <%- include('partials/navbar', { active: '' }) %>
  <% } else { %>
    <%- include('partials/public-nav') %>
  <% } %>

    <article class="post-wrap">
    <div class="post-hero-image">
      <img src="/images/blog/<%= post.image %>" alt="<%= post.title %>">
    </div>
    <div class="post-category"><%= post.category %></div>
    <h1 class="post-title"><%= post.title %></h1>
    <div class="post-date">Published <%= new Date(post.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></div>

    <div class="post-body">
      <% post.content.split('\n\n').forEach(paragraph => { %>
        <p><%= paragraph %></p>
      <% }) %>
    </div>

    <a href="/#insights" class="btn-outline-pill post-back-link">← Back to all insights</a>
  </article>
</body>
</html>